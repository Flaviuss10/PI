<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="erp.ui.DashboardController"
      spacing="30"
      style="-fx-padding: 30; -fx-background-color: #F9FAFB;">

    <!-- TITLU -->
    <Label text="ERP Dashboard"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #333;" />

    <!-- CARDURI INFORMATII -->
    <HBox spacing="20">
        <!-- Card: Total Comenzi -->
        <VBox spacing="5" alignment="CENTER"
              style="-fx-background-color: white; -fx-padding: 20; -fx-border-radius: 8; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, #ccc, 5, 0, 0, 2);">
            <Label text="Total Comenzi" style="-fx-font-size: 16;" />
            <Label fx:id="labelTotalOrders" text="125" style="-fx-font-size: 28px; -fx-font-weight: bold;" />
        </VBox>

        <!-- Card: Comenzi în Așteptare -->
        <VBox spacing="5" alignment="CENTER"
              style="-fx-background-color: white; -fx-padding: 20; -fx-border-radius: 8; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, #ccc, 5, 0, 0, 2);">
            <Label text="Comenzi în Așteptare" style="-fx-font-size: 16;" />
            <Label fx:id="labelPendingOrders" text="8" style="-fx-font-size: 28px; -fx-font-weight: bold;" />
        </VBox>

        <!-- Card: Stoc Ocupat -->
        <VBox spacing="10" alignment="CENTER"
              style="-fx-background-color: white; -fx-padding: 20; -fx-border-radius: 8; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, #ccc, 5, 0, 0, 2);">
            <Label text="Comenzi Finalizate" style="-fx-font-size: 16;" />
            <ProgressBar fx:id="finishedOrderProgressBar" progress="0.75" prefWidth="120" />
            <Label fx:id="labelFinishedOrderPercentage" text="75%" style="-fx-font-size: 14;" />
        </VBox>

        <!-- Card: Stocuri Critice -->
        <VBox spacing="5" alignment="CENTER"
              style="-fx-background-color: white; -fx-padding: 20; -fx-border-radius: 8; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, #ccc, 5, 0, 0, 2);">
            <Label text="Stocuri Critice" style="-fx-font-size: 16;" />
            <Label fx:id="labelCriticalStocks" text="5 produse" style="-fx-font-size: 18px; -fx-text-fill: #D9534F;" />
        </VBox>
    </HBox>

    <!-- TABEL ULTIMELE COMENZI -->
    <VBox spacing="10">
        <Label text="Ultimele Comenzi" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
        <TableView fx:id="tableRecentOrders" prefHeight="300">
            <columns>
                <TableColumn fx:id="colOrderId" text="ID" prefWidth="100" />
                <TableColumn fx:id="colClient" text="Client" prefWidth="200" />
                <TableColumn fx:id="colProduse" text="Produse" prefWidth="150" />
                <TableColumn fx:id="colStatus" text="Status" prefWidth="150" />
            </columns>
        </TableView>
    </VBox>

</VBox>
