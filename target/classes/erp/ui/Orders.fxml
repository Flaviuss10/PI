<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="erp.ui.OrdersController">

    <Label fx:id="titleLabel" style="-fx-font-size: 22;" text="Gestioneaza Comenzi" />

    <!-- Zona de căutare comenzi -->
    <HBox spacing="10">
        <TextField fx:id="searchField" promptText="Caută comandă după ID sau client" />
        <Button onAction="#onSearchOrder" text="🔎 Caută" />
      <Region prefHeight="25.0" prefWidth="118.0" HBox.hgrow="NEVER" />
      <Button fx:id="btnRefresh" mnemonicParsing="false" onAction="#handleRefresh" text="🗘 Reîncarcă" />
    </HBox>

    <Button fx:id="createOrderButton" onAction="#onCreateOrder" text="Creeaza Comanda Noua" />
   <Button fx:id="btnSterge" mnemonicParsing="false" onAction="#handleSterge" text="🗑 Șterge" textFill="RED" />

    <TableView fx:id="ordersTable">
        <columns>
            <TableColumn fx:id="colId" text="ID" />
            <TableColumn fx:id="colClient" text="Client" />
            <TableColumn fx:id="colProduse" text="Produse" />
            <TableColumn fx:id="colStatus" text="Status" />
        </columns>
    </TableView>

</VBox>
